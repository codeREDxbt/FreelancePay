{
    "include":  [
                    "src"
                ],
    "exclude":  [
                    "node_modules",
                    "lib"
                ],
    "compilerOptions":  {
                            "forceConsistentCasingInFileNames":  true,
                            "outDir":  "lib",
                            "lib":  [
                                        "es2022"
                                    ],
                            "resolveJsonModule":  true,
                            "declaration":  true,
                            "strict":  true,
                            "target":  "ES2022",
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "module":  "commonjs",
                            "rootDir":  "src"
                        }
}
