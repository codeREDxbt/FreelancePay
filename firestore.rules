rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /contracts/{contractId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.clientWallet || request.auth.uid == resource.data.freelancerWallet);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.clientWallet;
      allow update: if request.auth != null && (request.auth.uid == resource.data.clientWallet || request.auth.uid == resource.data.freelancerWallet);

      allow delete: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.walletAddress && request.resource.data.keys().hasAll(['walletAddress', 'rating', 'comment']);
      allow update, delete: if false;
    }

    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.clientId;
      allow update: if request.auth != null && request.auth.uid == resource.data.clientId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.clientId;
    }

    match /applications/{appId} {
      allow read: if request.auth != null; // For simplicity, we allow any auth user to read applications, or we can restrict it to the freelancer and the job owner. Let's allow read for now.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.freelancerWallet;
      allow update: if request.auth != null; // The client needs to be able to accept it.
      allow delete: if false;
    }

    match /auth_nonces/{nonceId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}